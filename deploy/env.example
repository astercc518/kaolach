# 复制为项目根目录 .env 后按需修改（.env 已被 git 忽略）
# 仓库已带 deploy/illyvoip-preview.service、deploy/nginx-cloudflare-origin.conf；可按需改域名后 systemctl / nginx reload
# 升级预览逻辑后：建议在 Cloudflare 对 HTML「开发模式」或「清除缓存」，避免边缘仍返回未改写 /cdn-cgi 的旧页面

# 监听地址：本机 127.0.0.1；公网或容器内被 Nginx 反代仍可用 127.0.0.1
# 若由 Node 直接对公网提供 HTTP，改为 0.0.0.0
PREVIEW_BIND=127.0.0.1

# 预览 HTTP 端口（与 deploy/nginx-cloudflare-origin.conf 中 upstream 一致）
PORT=8787

# 可选：在 Node 内直接启用 HTTPS（不设证书路径则仅 HTTP）
# 证书请使用 Cloudflare Origin Certificate 等新签发文件，勿使用已泄露私钥
# SSL_CERT_PATH=/etc/ssl/cloudflare/freeokcc-origin.pem
# SSL_KEY_PATH=/etc/ssl/cloudflare/freeokcc-origin.key
# HTTPS_PORT=8443
# HTTPS_BIND=0.0.0.0

# 中文页脚版权行显示名（修复快照里「伊利沃IP」等；默认取 PREVIEW_BRAND_NAME 或 考拉出海）
# PREVIEW_FOOTER_ZH_NAME=考拉出海

# 预览里页头字标文案（默认与品牌名一致）
# PREVIEW_LOGO_TEXT=kaolach

# 页面内「IllyVoIP / ILLYVOIP」等写法统一替换为该字符串（默认 kaolach；勿用含 HTML 特殊字符的值）
# PREVIEW_BRAND_NAME=kaolach

# 根路径 / 无 ?lang= 时使用的快照（清单里裸 / 常为 IT 等；默认 ?lang=en 英文）
# 设为 original 则保留爬虫当时的首页语言（且不启用下方地区推断）
# PREVIEW_DEFAULT_HOME_QUERY=?lang=en

# 根路径是否按 CF-IPCountry（经 Cloudflare 时）与 Accept-Language 推断首页语言（默认开启）
# 设为 0 则仅用 PREVIEW_DEFAULT_HOME_QUERY、?lang=en、裸 / 的回退顺序
# PREVIEW_GEO_HOME=1

# 可选：国家二位码 → lang 的 JSON 映射，用于覆盖或扩展内置表（lang 须为 en/es/fr/de/zh/ja/pt/hi/it 之一）
# PREVIEW_CC_LANG_JSON={"SG":"zh","CH":"de"}

# 用 Cookie 记住站点语言：中文首页后再点无 ?lang= 的内链时，仍尽量用同语言快照（默认开启）
# PREVIEW_LANG_PERSIST=1
# PREVIEW_LANG_COOKIE_NAME=preview_site_lang
# PREVIEW_LANG_COOKIE_MAX_AGE=31536000

# CookieYes：在非 illyvoip.com 域名预览时，原 CDN 脚本会因 registeredDomain 校验失败导致横幅按钮无响应。
# 默认开启本站代理并改写域名；设为 0 则仍从 cdn-cookieyes.com 加载（仅建议在正式域调试时关闭）
# PREVIEW_COOKIEYES_PROXY=1
# 快照里脚本写死的注册域（与 CDN bundle 一致，一般无需改）
# PREVIEW_COOKIEYES_LEGACY_DOMAIN=illyvoip.com
# 反代后若 CookieYes 仍报「URL has changed」：请确保 Nginx/CF 传入 X-Forwarded-Host（或在此写死公网域名，无端口）
# PREVIEW_COOKIEYES_REGISTERED_HOST=freeokcc.com
# PREVIEW_COOKIEYES_CACHE_MS=21600000

# 未命中快照时是否回源拉静态资源
PREVIEW_PROXY_MISS=1
LIVE_ORIGIN=https://illyvoip.com
